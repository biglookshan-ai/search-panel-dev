# Copy to .env locally, or set these as Railway variables (never commit real values).
# Embedded app — auth via App Bridge session token + OAuth token exchange.

SHOPIFY_API_KEY=            # App / Client ID (Partner Dashboard → app → API credentials)
SHOPIFY_API_SECRET=         # App / Client secret
SHOPIFY_API_VERSION=2026-04
DATA_DIR=/data              # Railway Volume mount so exchanged tokens survive redeploys

# --- Optional: skip token exchange with a fixed Admin API token (single store) ---
# SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx

PORT=3000

# --- Search analytics (optional; leave empty to disable) ---
# Add a Postgres service in Railway, then set this to its connection string.
# Easiest: reference the Postgres plugin var, e.g. ${{ Postgres.DATABASE_URL }}
DATABASE_URL=
# PGSSLMODE=require         # only if your Postgres URL needs SSL (e.g. external/public host)
