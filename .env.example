# Copy to .env locally, or set these as Railway variables (do NOT commit real values).
# Custom app Admin API access token (scopes: read/write metaobjects, read/write themes).
SHOPIFY_STORE=cinegearpro.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_VERSION=2025-01

# Optional: simple password to open the admin UI (recommended when hosted publicly).
ADMIN_UI_PASSWORD=

# Port (Railway sets this automatically).
PORT=3000
