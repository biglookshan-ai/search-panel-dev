# Copy to .env locally, or set these as Railway variables (never commit real values).

# Store to manage.
SHOPIFY_STORE=cinegearpro.myshopify.com
SHOPIFY_API_VERSION=2025-01

# --- OAuth (Partner / custom-distribution app) ---
SHOPIFY_API_KEY=            # App ID / Client ID (Partner Dashboard → app → API credentials)
SHOPIFY_API_SECRET=         # App secret / Client secret
SHOPIFY_SCOPES=read_metaobjects,write_metaobjects,read_themes,write_themes
APP_URL=https://your-app.up.railway.app   # this app's public URL (no trailing slash)
DATA_DIR=/data              # Railway Volume mount so the OAuth token survives redeploys

# Open the admin UI (recommended — the Railway URL is public).
ADMIN_UI_PASSWORD=

# --- Optional: skip OAuth entirely by pasting a fixed Admin API token ---
# (store-admin custom app token). If set, this wins and OAuth is not needed.
# SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx

PORT=3000
