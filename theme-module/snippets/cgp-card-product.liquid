{% comment %}
  CineGearPro custom product card — used on search results + collection pages.
  Fully self-contained: does NOT use the theme's card-product / price snippets.
  All styling comes from CSS variables (layout/theme.liquid) driven by
  Theme Settings → "Search & Collections". Behaviour lives in assets/cgp-card.js.

  Accepts:
  - card_product : {Object} product
  - section_id   : {String} unique id of the parent section
  - lazy_load    : {Boolean} lazy-load the image (optional)
{% endcomment %}

{%- liquid
  assign p = card_product

  # Selected variant.
  # When "default to first in-stock variant" is on, pick the first variant that
  # actually has stock — UK Inventory (real warehouse) or EW Inventory (virtual
  # buffer) > 0. Fall back to selected_or_first_available, then the first variant.
  if settings.cgp_default_first_available == false
    assign v = p.variants.first
  else
    assign v = blank
    for variant in p.variants
      if v == blank
        assign vuk = variant.metafields.custom.uk_inventory.value | default: 0
        assign vew = variant.metafields.custom.es_inventory.value | default: 0
        if vuk > 0 or vew > 0
          assign v = variant
        endif
      endif
    endfor
    if v == blank
      assign v = p.selected_or_first_available_variant
    endif
  endif

  # Best discount across all variants (drives the discount filter band)
  assign best_discount = 0
  for variant in p.variants
    if variant.compare_at_price > variant.price
      assign dvar = variant.compare_at_price | minus: variant.price | times: 100.0 | divided_by: variant.compare_at_price | round
      if dvar > best_discount
        assign best_discount = dvar
      endif
    endif
  endfor

  # Current selected-variant discount (visible price + discount badge)
  assign cur_on_sale = false
  assign cur_discount = 0
  if v.price > 0 and v.compare_at_price > v.price
    assign cur_on_sale = true
    assign cur_discount = v.compare_at_price | minus: v.price | times: 100.0 | divided_by: v.compare_at_price | round
  endif
-%}

{%- comment -%} Stock status of the selected variant {%- endcomment -%}
{%- capture cgp_status -%}{% render 'cgp-variant-status', variant: v %}{%- endcapture -%}
{%- assign status = cgp_status | strip -%}

<div class="cgp-card cgp-card--{{ status }}"
     data-cgp-card
     data-product-id="{{ p.id }}"
     data-discount="{{ best_discount }}"
     data-status="{{ status }}">

  {%- comment -%} ---------- Image + badges ---------- {%- endcomment -%}
  <div class="cgp-card__media">
    <a href="{{ p.url | within: collection | split: '?' | first }}" class="cgp-card__media-link" tabindex="-1" aria-hidden="true">
      {%- if p.featured_image -%}
        <img class="cgp-card__img"
             data-cgp-main-image="{{ p.featured_image | image_url: width: 600 }}"
             src="{{ p.featured_image | image_url: width: 600 }}"
             srcset="{{ p.featured_image | image_url: width: 300 }} 300w, {{ p.featured_image | image_url: width: 600 }} 600w, {{ p.featured_image | image_url: width: 900 }} 900w"
             sizes="(min-width: 990px) 300px, 45vw"
             width="{{ p.featured_image.width }}"
             height="{{ p.featured_image.height }}"
             alt="{{ p.featured_image.alt | escape }}"
             {% unless lazy_load == false %}loading="lazy"{% endunless %}>
        {%- if p.media[1] -%}
          <img class="cgp-card__img cgp-card__img--hover"
               src="{{ p.media[1] | image_url: width: 600 }}"
               srcset="{{ p.media[1] | image_url: width: 300 }} 300w, {{ p.media[1] | image_url: width: 600 }} 600w"
               sizes="(min-width: 990px) 300px, 45vw" alt="" loading="lazy" aria-hidden="true">
        {%- endif -%}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'cgp-card__img placeholder-svg' }}
      {%- endif -%}
    </a>

    {%- if settings.cgp_show_discount_badge -%}
      <span class="cgp-badge cgp-badge--discount{% unless cur_discount > 0 %} cgp-hidden{% endunless %}"
            data-cgp-discount-badge data-suffix="{{ settings.cgp_badge_disc_suffix | escape }}">{{ cur_discount }}{{ settings.cgp_badge_disc_suffix }}</span>
    {%- endif -%}

    {%- liquid
      assign status_label = settings.cgp_badge_instock_label
      if status == 'preorder'
        assign status_label = settings.cgp_badge_preorder_label
      elsif status == 'oos'
        assign status_label = settings.cgp_badge_oos_label
      endif
      assign hide_status = false
      if status == 'instock' and settings.cgp_show_instock_badge == false
        assign hide_status = true
      endif
    -%}
    <span class="cgp-badge cgp-badge--status cgp-badge--{{ status }}{% if hide_status %} cgp-hidden{% endif %}"
          data-cgp-status>{{ status_label }}</span>

    {%- comment -%} Product-status badges (Coming Soon / Clearance …) overlay bottom-right. {%- endcomment -%}
    {%- render 'cgp-status-badges', product: p -%}
  </div>

  {%- comment -%} Custom badges render below the image (left / right). {%- endcomment -%}
  {%- render 'cgp-custom-badges', product: p -%}

  {%- comment -%} ---------- Info ---------- {%- endcomment -%}
  <div class="cgp-card__info">
    {%- if p.metafields.custom.promotion_tag.value.size > 0 -%}
      <div class="cgp-promos">
        {%- for promo in p.metafields.custom.promotion_tag.value -%}
          {%- assign sip = promo.show_in_search_page.value | downcase -%}
          {%- unless sip == 'false' -%}
            {%- capture pbody %}{{ promo.description | metafield_tag }}{% endcapture -%}
            {%- capture pcta %}{{ promo.cta | metafield_tag }}{% endcapture -%}
            {%- assign plabel = promo.short_description.value -%}
            {%- if plabel == blank %}{%- assign plabel = promo.title.value -%}{%- endif -%}
            {%- if plabel == blank %}{%- assign plabel = pbody | strip_html | truncate: 80 -%}{%- endif -%}
            <button type="button" class="cgp-promo" data-cgp-promo>
              <span class="cgp-promo__label">{{ plabel | escape }}</span>
              <span class="cgp-promo__data" hidden>
                <span class="cgp-promo__t">{{ promo.title.value | escape }}</span>
                <span class="cgp-promo__b">{{ pbody }}</span>
                <span class="cgp-promo__c">{{ pcta }}</span>
              </span>
            </button>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
    <a href="{{ p.url | within: collection | split: '?' | first }}" class="cgp-card__title-link">
      <h3 class="cgp-card__title">{{ p.title | escape }}</h3>
    </a>

    {%- comment -%} Variant dropdown (only if multiple variants) {%- endcomment -%}
    {%- unless p.has_only_default_variant -%}
      <div class="cgp-card__options">
        {%- if settings.cgp_show_option_label -%}
          <label class="cgp-card__option-label" for="cgp-variant-{{ section_id }}-{{ p.id }}">{{ p.options.first }}:</label>
        {%- endif -%}
        <select class="cgp-card__variant"
                id="cgp-variant-{{ section_id }}-{{ p.id }}"
                data-cgp-variant
                aria-label="{{ p.options.first | default: 'Variant' }}">
          {%- for variant in p.variants -%}
            <option value="{{ variant.id }}"
                    data-price="{{ variant.price }}"
                    data-compare="{{ variant.compare_at_price | default: 0 }}"
                    data-price-str="{{ variant.price | money | escape }}"
                    data-compare-str="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money | escape }}{% endif %}"
                    data-image="{% if variant.featured_image %}{{ variant.featured_image | image_url: width: 600 }}{% endif %}"
                    data-available="{{ variant.available }}"
                    data-policy="{{ variant.inventory_policy }}"
                    data-uk="{{ variant.metafields.custom.uk_inventory.value | default: 0 }}"
                    data-ew="{{ variant.metafields.custom.es_inventory.value | default: 0 }}"
                    {% if variant == v %}selected{% endif %}>
              {{ variant.title }}
            </option>
          {%- endfor -%}
        </select>
      </div>
    {%- endunless -%}

    {%- comment -%} Price + action buttons row {%- endcomment -%}
    <div class="cgp-card__price-actions">
      <div class="cgp-card__price" data-cgp-price>
        {%- if cur_on_sale and v.price > 0 -%}
          <span class="cgp-card__price-compare" data-cgp-compare>{{ v.compare_at_price | money }}</span>
        {%- endif -%}
        <span class="cgp-card__price-current" data-cgp-current>{% if v.price > 0 %}{{ v.price | money }}{% else %}£TBC{% endif %}</span>
        <span class="cgp-card__price-vat">{{ settings.cgp_vat_label }}</span>
      </div>

      {%- if settings.cgp_show_wishlist or settings.cgp_show_add_cart -%}
        <div class="cgp-card__actions">
          {%- if settings.cgp_show_wishlist -%}
            <div class="xb-wishlist__btn-custom">
              <div class="xb-wishlist__add"
                   xb-product-id="{{ p.id }}"
                   xb-product-title="{{ p.title | escape }}"
                   xb-product-variant="{{ v.id }}"
                   xb-is-in-stock="{{ p.available }}"
                   xb-product-handle="{{ p.handle }}">
                <button type="button" class="cgp-action-btn" aria-label="Add to wishlist">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                </button>
              </div>
              <div class="xb-wishlist__loading" xb-product-id="{{ p.id }}">Loading...</div>
              <div class="xb-wishlist__remove" xb-product-id="{{ p.id }}" xb-is-in-stock="{{ p.available }}">
                <button type="button" class="cgp-action-btn cgp-action-btn--active" aria-label="Remove from wishlist">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                </button>
              </div>
            </div>
          {%- endif -%}

          {%- if settings.cgp_show_add_cart -%}
            <button type="button"
                    class="cgp-action-btn cgp-card__add-cart"
                    data-cgp-add-cart
                    data-variant-id="{{ v.id }}"
                    {% if status == 'oos' %}disabled{% endif %}
                    aria-label="Add to cart">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"></circle><circle cx="20" cy="21" r="1"></circle><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path></svg>
            </button>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>
