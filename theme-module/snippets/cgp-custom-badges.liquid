{%- comment -%}
  Renders tag-triggered custom badges. Data source: Metaobject "cgp_badge"
  (metaobjects.cgp_badge.values). Each entry:
    - tag         (single line text)  trigger product tag (case-sensitive)
    - position    (single line text)  top-left | top-right | bottom-left | bottom-right
    - label       (single line text)  badge text (optional)
    - image       (file: image)       optional, overrides text
    - background  (color)             text-badge background
    - text_color  (color)             text-badge colour
    - enabled     (boolean)           optional; false hides the rule
    - link        (single line text)  optional URL; if blank we auto-link to the
                                       collection whose handle == handleize(tag).
                                       When a link resolves, the badge is clickable.
  placement:
    - 'over'  (default) → top-left / top-right, overlaid on the image
    - 'below'           → bottom-left / bottom-right, rendered BELOW the image
                          (does not cover the product image)
  Accepts: product, placement
{%- endcomment -%}
{%- liquid
  assign badge_defs = metaobjects.cgp_badge.values
  assign placement = placement | default: 'over'
  if placement == 'below'
    assign corners = 'bottom-left,bottom-right' | split: ','
  else
    assign corners = 'top-left,top-right' | split: ','
  endif
-%}
{%- if badge_defs.size > 0 -%}
  {%- assign any = '' -%}
  {%- capture group_html -%}
    {%- for corner in corners -%}
      {%- capture corner_html -%}
        {%- for b in badge_defs -%}
          {%- if b.enabled.value == false -%}{%- continue -%}{%- endif -%}
          {%- assign btag = b.tag.value -%}
          {%- assign bpos = b.position.value | default: 'bottom-left' | strip -%}
          {%- if btag != blank and bpos == corner and product.tags contains btag -%}
            {%- comment -%} Resolve the click-through link: manual field first, else collection by handle. {%- endcomment -%}
            {%- assign bhref = b.link.value | default: '' | strip -%}
            {%- if bhref == blank -%}
              {%- assign bhandle = btag | handleize -%}
              {%- assign bcol = collections[bhandle] -%}
              {%- if bcol.id -%}{%- assign bhref = bcol.url -%}{%- endif -%}
            {%- endif -%}
            {%- assign bimg = b.image.value -%}
            {%- if bimg != blank -%}
              {%- assign bcls = 'cgp-cbadge cgp-cbadge--img' -%}
              {%- assign bstyle = '' -%}
              {%- capture bcontent -%}<img src="{{ bimg | image_url: width: 240 }}" alt="{{ b.label.value | escape }}" loading="lazy">{%- endcapture -%}
            {%- else -%}
              {%- assign bcls = 'cgp-cbadge' -%}
              {%- capture bstyle -%}background:{{ b.background.value | default: '#1c222d' }};color:{{ b.text_color.value | default: '#ffffff' }};{%- endcapture -%}
              {%- capture bcontent -%}{{ b.label.value }}{%- endcapture -%}
            {%- endif -%}
            {%- if bhref != blank -%}
              <a class="{{ bcls }} cgp-cbadge--link" href="{{ bhref }}" style="{{ bstyle }}" data-track="custom-badge">{{ bcontent }}</a>
            {%- else -%}
              <span class="{{ bcls }}" style="{{ bstyle }}">{{ bcontent }}</span>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}
      {%- assign corner_stripped = corner_html | strip -%}
      {%- if corner_stripped != blank -%}
        <div class="cgp-cbadges cgp-cbadges--{{ corner }}">{{ corner_html }}</div>
        {%- assign any = 'y' -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}
  {%- if any != blank -%}
    {%- if placement == 'below' -%}
      <div class="cgp-cbadges-below">{{ group_html }}</div>
    {%- else -%}
      {{ group_html }}
    {%- endif -%}
  {%- endif -%}
{%- endif -%}
