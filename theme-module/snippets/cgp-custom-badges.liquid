{%- comment -%}
  Tag-triggered custom badges, rendered BELOW the product image (never over it).
  Data: metaobject cgp_badge. Fields:
    - tag         (single line text)  trigger product tag
    - position    (single line text)  left | right (default left)
    - label       (single line text)  badge text
    - image       (file: image)       optional, overrides text
    - background  (color)             text-badge background
    - text_color  (color)             text-badge colour
    - enabled     (boolean)           false hides the rule
    - link        (URL)               optional; filled = clickable (underlined)
  position: any value containing "right" → right side; anything else → left.
  Same-side multiples follow metaobject order. Accepts: product
{%- endcomment -%}
{%- liquid
  assign badge_defs = metaobjects.cgp_badge.values
-%}
{%- if badge_defs.size > 0 -%}
  {%- assign any = '' -%}
  {%- capture group_html -%}
    {%- for side in 'left,right' | split: ',' -%}
      {%- capture side_html -%}
        {%- for b in badge_defs -%}
          {%- if b.enabled.value == false -%}{%- continue -%}{%- endif -%}
          {%- assign btag = b.tag.value -%}
          {%- assign bpos = b.position.value | default: 'left' | downcase -%}
          {%- assign bside = 'left' -%}
          {%- if bpos contains 'right' -%}{%- assign bside = 'right' -%}{%- endif -%}
          {%- if btag != blank and bside == side and product.tags contains btag -%}
            {%- comment -%} Only an explicitly-filled link makes a badge clickable (Link type → .url, text/url type → string). {%- endcomment -%}
            {%- assign bhref = '' -%}
            {%- if b.link.value.url != blank -%}
              {%- assign bhref = b.link.value.url -%}
            {%- elsif b.link.value != blank -%}
              {%- assign bhref = b.link.value -%}
            {%- endif -%}
            {%- assign bhref = bhref | strip -%}
            {%- assign bimg = b.image.value -%}
            {%- if bimg != blank -%}
              {%- assign bcls = 'cgp-cbadge cgp-cbadge--img' -%}
              {%- assign bstyle = '' -%}
              {%- capture bcontent -%}<img src="{{ bimg | image_url: width: 240 }}" alt="{{ b.label.value | escape }}" loading="lazy">{%- endcapture -%}
            {%- else -%}
              {%- assign bcls = 'cgp-cbadge' -%}
              {%- capture bstyle -%}background:{{ b.background.value | default: '#1c222d' }};color:{{ b.text_color.value | default: '#ffffff' }};{%- endcapture -%}
              {%- capture bcontent -%}{{ b.label.value }}{%- endcapture -%}
            {%- endif -%}
            {%- if bhref != blank -%}
              <a class="{{ bcls }} cgp-cbadge--link" href="{{ bhref }}" style="{{ bstyle }}" data-track="custom-badge">{{ bcontent }}</a>
            {%- else -%}
              <span class="{{ bcls }}" style="{{ bstyle }}">{{ bcontent }}</span>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}
      {%- assign side_stripped = side_html | strip -%}
      {%- if side_stripped != blank -%}
        <div class="cgp-cbadges cgp-cbadges--{{ side }}">{{ side_html }}</div>
        {%- assign any = 'y' -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endcapture -%}
  {%- if any != blank -%}
    <div class="cgp-cbadges-below">{{ group_html }}</div>
  {%- endif -%}
{%- endif -%}
